{
  "name": "shared-agents-memory",
  "version": "0.1.0",
  "description": "Shared agent memory MCP service backed by Qdrant and OpenRouter embeddings",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:inspect": "tsx --inspect src/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "npm run typecheck && npm run lint && npm run test",
    "clean": "rm -rf dist",
    "migrate:claude-memory": "tsx scripts/migrate-claude-memory.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@node-rs/argon2": "^2.0.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "@qdrant/js-client-rest": "^1.13.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.8.5",
    "otpauth": "^9.5.1",
    "prom-client": "^15.1.3",
    "yaml": "^2.9.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.0"
  }
}
