# Copy to .env and fill in the values you need.
# Vars are consumed by both `npm run dev` (stdio mode) and `docker compose`.

# --- Embeddings provider (OpenAI-compatible API; required) ---
# Works with OpenRouter, OpenAI proper, vLLM, Together, Anyscale, Ollama
# (OpenAI-compat mode), llama.cpp server, etc. Defaults target OpenRouter +
# qwen3 per ADR-0005 — change BASE_URL and MODEL to point at any other
# OpenAI-compatible endpoint.
# Get an OpenRouter key at https://openrouter.ai/keys (or use your provider).
# For the self-host CIS profile (ADR-0010) point this at a local embedding
# server (TEI / Infinity / Ollama) exposing an OpenAI-compatible /embeddings,
# e.g. EMBEDDINGS_BASE_URL=http://embedder:80/v1 and EMBEDDINGS_API_KEY=local.
EMBEDDINGS_API_KEY=
EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1
# Embedding model. Self-host default is bge-m3 (1024-dim); the cloud default
# below is qwen3 (4096-dim) — set EMBEDDINGS_DIMENSION to match the model.
EMBEDDINGS_MODEL=qwen/qwen3-embedding-8b
# Vector dimension — provider-driven, immutable once the Qdrant collection
# exists (ADR-0010 §3.3). Default 1024 (bge-m3). Cloud qwen3 deployments: 4096.
EMBEDDINGS_DIMENSION=1024

# --- Qdrant ---
# Use http://qdrant:6333 when running the MCP server inside docker-compose.
# Use http://localhost:6333 when running `npm run dev` against `docker compose up qdrant`.
QDRANT_URL=http://localhost:6333
# Optional API key. In production set BOTH of the following to the same
# secret — the first is consumed by the MCP client, the second is read by the
# Qdrant server itself. Leave both UNSET (delete the lines) in dev to disable
# auth; an empty value enables auth-with-empty-key and breaks every request.
# QDRANT_API_KEY=changeme
# QDRANT__SERVICE__API_KEY=changeme
QDRANT_COLLECTION=agent_memories
# Vector quantization (ADR-0010 §3.4) — int8 + rescore makes the box hold ~4x
# more vectors near-losslessly. Set QDRANT_QUANTIZATION=none to store full fp32.
QDRANT_QUANTIZATION=int8
QDRANT_RESCORE=true
QDRANT_OVERSAMPLING=2.0

# --- MCP server (stdio-mode scaffold today) ---
# HTTP transport ships in issue #22 (ADR-0003); the env vars TRANSPORT,
# HTTP_BIND_HOST, HTTP_BIND_PORT, HTTP_PUBLIC_ORIGIN and friends will be
# documented here once that lands.
MCP_SERVER_PORT=3000

# --- Storage ---
# Root for namespace, auth, rule, and audit data. Bind-mounted into the `mcp`
# container by docker-compose. Defaults to ./data.
DATA_DIR=./data

# --- Auth (ADR-0004) ---
# PAT hashing pepper (32 bytes / 64 hex chars). Auto-generated on first boot
# and written to data/_auth/.pepper (mode 0600). Mirror that value here so
# both copies agree — the server refuses to start on mismatch.
SERVER_PEPPER=

# stdio transport only: the PAT this process binds to for its lifetime
# (ADR-0004 §3.6). Required when TRANSPORT=stdio; ignored when TRANSPORT=http.
LOCAL_STDIO_AGENT_PAT=

# auth.success audit sampling rate, range [0, 1] (ADR-0004 §5.1 Q4).
# Default 0.1. auth.failure is always recorded at full rate.
# AUDIT_SUCCESS_SAMPLE_RATE=0.1

# --- Namespace defaults (ADR-0002 §3.4, §5.1 Q2) ---
# Override the per-namespace quota defaults applied at namespace creation.
# Operators can still tighten or relax these per namespace via
# namespace.update_quota once #20 ships.
# DEFAULT_NS_DAILY_EMBEDDING_TOKENS=1000000
# DEFAULT_NS_DAILY_WRITES=5000
# DEFAULT_NS_DAILY_SEARCHES=20000
# DEFAULT_NS_MAX_MEMORIES=100000

# --- docker-compose http profile (placeholder until issue #22) ---
# The reverse-proxy origin used for the Origin header check in HTTP mode.
# Match this to the public URL your TLS proxy serves the MCP endpoint at.
# HTTP_PUBLIC_ORIGIN=https://memory.example.com

# --- Admin console (ADR-0007 / ADR-0008) ---
# The operator web console runs as a SEPARATE listener from the MCP transport
# and is OFF by default. Enabling it changes nothing about the MCP path.
# ADMIN_ENABLED=false
# ADMIN_BIND_HOST=127.0.0.1          # 0.0.0.0 inside Docker (compose sets this)
# ADMIN_BIND_PORT=8081
# ADMIN_COOKIE_SECURE=true           # set false only for a plain-HTTP local bring-up
# ADMIN_TRUST_PROXY=true             # true behind the reverse proxy; false for direct exposure
