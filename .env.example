# OpenRouter
OPENROUTER_API_KEY=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# MCP Server
MCP_SERVER_PORT=3000

# Storage root for namespace, auth, and rule data. Defaults to ./data.
DATA_DIR=./data

# Auth — PAT hashing pepper. Auto-generated on first boot and mirrored to
# data/_auth/.pepper. After first boot, set this env var to the same hex value
# (32 bytes / 64 hex chars). The server fails to start if the two disagree.
SERVER_PEPPER=

# Auth — stdio transport only. The PAT this process binds to for its lifetime
# (ADR-0004 §3.6). Required when TRANSPORT=stdio; ignored when TRANSPORT=http.
LOCAL_STDIO_AGENT_PAT=
