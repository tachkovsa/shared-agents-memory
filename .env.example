# Copy to .env and fill in the values you need.
# Vars are consumed by both `npm run dev` (stdio mode) and `docker compose`.

# --- Embeddings provider (required) ---
# EMBEDDINGS_PROVIDER selects the protocol:
#   openai   (default) — any OpenAI-compatible API: OpenRouter, OpenAI, vLLM,
#                        Together, Anyscale, Ollama (OpenAI-compat), TEI, …
#   gigachat           — Sber GigaChat (OAuth token flow; Russian-language)
#   yandex             — Yandex Cloud Foundation Models
# Leave unset for `openai`. Pick ONE profile below.
#
# CRITICAL: EMBEDDINGS_MODEL and EMBEDDINGS_DIMENSION must agree. The dimension
# is immutable once the Qdrant collection exists (ADR-0010 §3.3); a mismatch
# makes every embedding call fail with EmbeddingDimensionError. Switching models
# (even at the same dimension) also changes the vector space — re-embed the
# existing collection via scripts/reembed-collection.ts. The values in each
# profile below are pre-matched — don't mix lines across profiles.
#
# --- Profile A: self-host (ADR-0010 default) — local TEI + bge-m3, 1024-dim ---
# Run the embedder sidecar via docker-compose.embedder.yml; no external key.
EMBEDDINGS_API_KEY=local
EMBEDDINGS_BASE_URL=http://embedder/v1
EMBEDDINGS_MODEL=bge-m3
EMBEDDINGS_DIMENSION=1024
#
# --- Profile B: cloud — OpenRouter + qwen3 (ADR-0005), 4096-dim ---
# Get a key at https://openrouter.ai/keys. To use this profile, comment out
# Profile A above and uncomment these four lines:
# EMBEDDINGS_API_KEY=sk-or-v1-...
# EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1
# EMBEDDINGS_MODEL=qwen/qwen3-embedding-8b
# EMBEDDINGS_DIMENSION=4096
#
# --- Profile C: GigaChat (Sber) — EmbeddingsGigaR, 2560-dim ---
# Good Russian-language quality; no local RAM cost (external API). To use it,
# comment out Profile A and uncomment these lines. EMBEDDINGS_API_KEY is the
# base64 "Authorization key" (ключ авторизации) from the GigaChat cabinet — the
# server exchanges it for a short-lived OAuth token automatically.
# EMBEDDINGS_PROVIDER=gigachat
# EMBEDDINGS_API_KEY=<base64-authorization-key>
# EMBEDDINGS_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
# GigaChat has two embedding models. Pick ONE (model + matching dimension):
#   EmbeddingsGigaR — 2560-dim, ~4096-token context. Recommended: it fits
#                     multi-KB memories (most stored memories exceed the small
#                     model's limit). This is what the ArtelMemory box runs.
#   Embeddings      — 1024-dim, ~514-token context. Only for short memories.
# EMBEDDINGS_MODEL=EmbeddingsGigaR
# EMBEDDINGS_DIMENSION=2560
# EMBEDDINGS_SCOPE=GIGACHAT_API_PERS   # or GIGACHAT_API_B2B / GIGACHAT_API_CORP
# GigaChat has NO server-side auto-truncation (unlike TEI): an input above the
# model's token limit is rejected with HTTP 413. The client adaptively truncates
# on a 413, but set a static char cap to skip the wasted first over-limit call.
# 0 = disabled. 8000 chars is a safe start for EmbeddingsGigaR on Russian text.
# EMBEDDINGS_MAX_INPUT_CHARS=8000
# REQUIRED: GigaChat's TLS chain is signed by the Минцифры root CA, which Node
# does not trust by default. Point NODE_EXTRA_CA_CERTS at that CA bundle or every
# call fails with SELF_SIGNED_CERT_IN_CHAIN. The PEM is committed under certs/
# and baked into the image at /app/certs. See certs/README.md.
# NODE_EXTRA_CA_CERTS=/app/certs/russian_trusted_root_ca.pem
#
# --- Profile D: YandexGPT (Yandex Cloud) — text-search-doc, 256-dim ---
# EMBEDDINGS_API_KEY is a service-account API key (or an OAuth token when
# EMBEDDINGS_AUTH_METHOD=IAM_TOKEN). EMBEDDINGS_FOLDER_ID is required.
# EMBEDDINGS_PROVIDER=yandex
# EMBEDDINGS_API_KEY=<yandex-api-key-or-oauth-token>
# EMBEDDINGS_FOLDER_ID=<b1g...>
# EMBEDDINGS_BASE_URL=https://llm.api.cloud.yandex.net/foundationModels/v1
# EMBEDDINGS_MODEL=text-search-doc     # query side: text-search-query
# EMBEDDINGS_DIMENSION=256
# EMBEDDINGS_AUTH_METHOD=API_KEY       # or IAM_TOKEN

# --- Local embedder sidecar (Profile A only; docker-compose.embedder.yml) ---
# TEI_IMAGE_TAG=cpu-1.9
# EMBEDDINGS_MODEL_ID=BAAI/bge-m3
# TEI_DATA_DIR=/var/lib/shared-agents-memory/tei
# Warmup/batch token cap. Default 4096 fits the 8GB reference box (~5GB RSS); the
# TEI default of 16384 OOM-kills it. Raise only with more RAM. A single input
# above this many tokens is rejected, so don't lower it below your largest memory.
# TEI_MAX_BATCH_TOKENS=4096

# --- Qdrant ---
# Use http://qdrant:6333 when running the MCP server inside docker-compose.
# Use http://localhost:6333 when running `npm run dev` against `docker compose up qdrant`.
QDRANT_URL=http://localhost:6333
# Optional API key. In production set BOTH of the following to the same
# secret — the first is consumed by the MCP client, the second is read by the
# Qdrant server itself. Leave both UNSET (delete the lines) in dev to disable
# auth; an empty value enables auth-with-empty-key and breaks every request.
# QDRANT_API_KEY=changeme
# QDRANT__SERVICE__API_KEY=changeme
QDRANT_COLLECTION=agent_memories
# Vector quantization (ADR-0010 §3.4) — int8 + rescore makes the box hold ~4x
# more vectors near-losslessly. Set QDRANT_QUANTIZATION=none to store full fp32.
QDRANT_QUANTIZATION=int8
QDRANT_RESCORE=true
QDRANT_OVERSAMPLING=2.0

# --- MCP server (stdio-mode scaffold today) ---
# HTTP transport ships in issue #22 (ADR-0003); the env vars TRANSPORT,
# HTTP_BIND_HOST, HTTP_BIND_PORT, HTTP_PUBLIC_ORIGIN and friends will be
# documented here once that lands.
MCP_SERVER_PORT=3000

# --- Storage ---
# Root for namespace, auth, rule, and audit data. Bind-mounted into the `mcp`
# container by docker-compose. Defaults to ./data.
DATA_DIR=./data

# --- Auth (ADR-0004) ---
# PAT hashing pepper (32 bytes / 64 hex chars). Auto-generated on first boot
# and written to data/_auth/.pepper (mode 0600). Mirror that value here so
# both copies agree — the server refuses to start on mismatch.
SERVER_PEPPER=

# stdio transport only: the PAT this process binds to for its lifetime
# (ADR-0004 §3.6). Required when TRANSPORT=stdio; ignored when TRANSPORT=http.
LOCAL_STDIO_AGENT_PAT=

# auth.success audit sampling rate, range [0, 1] (ADR-0004 §5.1 Q4).
# Default 0.1. auth.failure is always recorded at full rate.
# AUDIT_SUCCESS_SAMPLE_RATE=0.1

# --- Namespace defaults (ADR-0002 §3.4, §5.1 Q2) ---
# Override the per-namespace quota defaults applied at namespace creation.
# Operators can still tighten or relax these per namespace via
# namespace.update_quota once #20 ships.
# DEFAULT_NS_DAILY_EMBEDDING_TOKENS=1000000
# DEFAULT_NS_DAILY_WRITES=5000
# DEFAULT_NS_DAILY_SEARCHES=20000
# DEFAULT_NS_MAX_MEMORIES=100000

# --- docker-compose http profile (placeholder until issue #22) ---
# The reverse-proxy origin used for the Origin header check in HTTP mode.
# Match this to the public URL your TLS proxy serves the MCP endpoint at.
# HTTP_PUBLIC_ORIGIN=https://memory.example.com

# --- Admin console (ADR-0007 / ADR-0008) ---
# The operator web console runs as a SEPARATE listener from the MCP transport
# and is OFF by default. Enabling it changes nothing about the MCP path.
# ADMIN_ENABLED=false
# ADMIN_BIND_HOST=127.0.0.1          # 0.0.0.0 inside Docker (compose sets this)
# ADMIN_BIND_PORT=8081
# ADMIN_COOKIE_SECURE=true           # set false only for a plain-HTTP local bring-up
# ADMIN_TRUST_PROXY=true             # true behind the reverse proxy; false for direct exposure
