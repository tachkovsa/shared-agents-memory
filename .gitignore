node_modules/
dist/
.env
.env.local
.env.*.local
*.tsbuildinfo
coverage/

# Runtime state — namespace dir, rule store, PAT store, audit logs.
# Bind-mounted into the `mcp` container by docker-compose; created on first boot.
data/

# Claude Code per-user state (shared .claude/settings.json stays trackable).
.claude/settings.local.json
.claude/worktrees/

# Local scratch — analysis notes, internal strategy. Never committed.
temp/

# Design screenshots — generated locally, not tracked.
design/screenshots/

# Extra CA certs. The PUBLIC Минцифры root CA (needed for GigaChat TLS) is
# committed below so operators don't have to hunt it down behind a VPN. Any
# OTHER cert/key material stays ignored — never commit private keys.
certs/*.pem
certs/*.crt
certs/*.cer
!certs/russian_trusted_root_ca.pem
